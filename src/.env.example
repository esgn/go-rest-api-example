# ── Server ────────────────────────────────────────────────────────────────────
HTTP_ADDR=:8080
# debug | info | warn | error
LOG_LEVEL=info

# ── Database ──────────────────────────────────────────────────────────────────
SQLITE_PATH=./notes.db
DB_MAX_OPEN_CONNS=10
DB_MAX_IDLE_CONNS=10

# ── Service / Business rules ─────────────────────────────────────────────────
NOTE_MAX_CONTENT_LENGTH=10000
NOTE_MAX_TITLE_LENGTH=50
PAGE_DEFAULT_LIMIT=20
PAGE_MAX_LIMIT=100
